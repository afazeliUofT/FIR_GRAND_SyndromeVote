#!/bin/bash

# ===== Slurm resources =====
# Dedicated "absolute-winner" comparison:
#   legacy ldpc100  vs  hybbgr100
# with paired frame streams and multi-snapshot rescue.
#SBATCH --time=18:00:00
#SBATCH --cpus-per-task=64
#SBATCH --mem=0
#SBATCH --output=logs/%x-%j.out
#SBATCH --error=logs/%x-%j.err

set -euo pipefail

mkdir -p logs results

module --force purge
module load StdEnv/2023 python/3.11 scipy-stack/2024a

VENV_DIR="${VENV_DIR:-$SCRATCH/venvs/grand5g}"
if [[ ! -d "$VENV_DIR" ]]; then
  echo "ERROR: venv not found: $VENV_DIR"
  echo "Create it first (see README / UPGRADE_INSTRUCTIONS)."
  exit 1
fi
source "$VENV_DIR/bin/activate"

export TMPDIR="${TMPDIR:-${SLURM_TMPDIR:-/tmp}}"
export NUMBA_CACHE_DIR="${NUMBA_CACHE_DIR:-$TMPDIR/numba_cache}"
export JOBLIB_TEMP_FOLDER="${JOBLIB_TEMP_FOLDER:-$TMPDIR/joblib}"
mkdir -p "$NUMBA_CACHE_DIR" "$JOBLIB_TEMP_FOLDER"

# ===== Performance / fairness knobs =====
export USE_GPU=${USE_GPU:-0}
if [[ "${USE_GPU}" != "1" ]]; then
  export CUDA_VISIBLE_DEVICES="-1"
  export TF_CPP_MIN_LOG_LEVEL=${TF_CPP_MIN_LOG_LEVEL:-2}
fi
export TF_INTRA_OP=${TF_INTRA_OP:-1}
export TF_INTER_OP=${TF_INTER_OP:-1}

export MAX_NB_THREADS=${MAX_NB_THREADS:-${SLURM_CPUS_PER_TASK:-64}}
export LDPC_GRAND_NUM_THREADS=${LDPC_GRAND_NUM_THREADS:-${SLURM_CPUS_PER_TASK:-64}}
export SNR_MIN_THREADS_PER_WORKER=${SNR_MIN_THREADS_PER_WORKER:-16}
export PARALLEL_OVER_SNR=${PARALLEL_OVER_SNR:-1}
export PAIR_DECODER_STREAMS=${PAIR_DECODER_STREAMS:-1}
export GRAND_RESCUE_SNAPSHOT_ITERS=${GRAND_RESCUE_SNAPSHOT_ITERS:-"4,8,12,15,20,40,60,80,100"}

export OMP_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export MKL_NUM_THREADS=1
export VECLIB_MAXIMUM_THREADS=1
export NUMEXPR_NUM_THREADS=1

# ===== Core experiment =====
export CHANNEL_NAME=SIONNA_TDL
export SIONNA_5G_K=${SIONNA_5G_K:-1024}
export SIONNA_5G_N=${SIONNA_5G_N:-2048}
export SIONNA_5G_QM=${SIONNA_5G_QM:-1}

# Targeted moderate-impairment regime where localized rescue can matter.
export SIONNA_TDL_MODEL=${SIONNA_TDL_MODEL:-C}
export SIONNA_TDL_DELAY_SPREAD_S=${SIONNA_TDL_DELAY_SPREAD_S:-8e-7}
export SIONNA_TDL_CARRIER_FREQUENCY_HZ=${SIONNA_TDL_CARRIER_FREQUENCY_HZ:-3.5e9}
export SIONNA_TDL_MIN_SPEED=${SIONNA_TDL_MIN_SPEED:-8.0}
export SIONNA_TDL_MAX_SPEED=${SIONNA_TDL_MAX_SPEED:-14.0}

export SIONNA_OFDM_FFT_SIZE=${SIONNA_OFDM_FFT_SIZE:-512}
export SIONNA_OFDM_SUBCARRIER_SPACING_HZ=${SIONNA_OFDM_SUBCARRIER_SPACING_HZ:-15000}
export SIONNA_CFO_HZ=${SIONNA_CFO_HZ:-120.0}

export SIONNA_CSI_MODE=${SIONNA_CSI_MODE:-nr_imperfect}
export SIONNA_CSI_PILOT_STRIDE=${SIONNA_CSI_PILOT_STRIDE:-18}
export SIONNA_CSI_SMOOTH_PILOTS=${SIONNA_CSI_SMOOTH_PILOTS:-1}
export SIONNA_CSI_EST_SNR_DB=${SIONNA_CSI_EST_SNR_DB:-14}
export SIONNA_CSI_PHASE_DRIFT_STD_DEG=${SIONNA_CSI_PHASE_DRIFT_STD_DEG:-1.5}
export SIONNA_CSI_AMP_RIPPLE_DB=${SIONNA_CSI_AMP_RIPPLE_DB:-1.0}
export SIONNA_CSI_DELAY_BIAS_NS=${SIONNA_CSI_DELAY_BIAS_NS:-10.0}
export SIONNA_CSI_BLOCK_SC=${SIONNA_CSI_BLOCK_SC:-12}
export SIONNA_LLR_MAX=${SIONNA_LLR_MAX:-50.0}

# Only compare the strongest legacy baseline against Receiver-7.
export RUN_RECEIVER1=${RUN_RECEIVER1:-0}
export RUN_RECEIVER2=${RUN_RECEIVER2:-0}
export RUN_RECEIVER3=${RUN_RECEIVER3:-0}
export RUN_RECEIVER4=${RUN_RECEIVER4:-0}
export RUN_RECEIVER5=${RUN_RECEIVER5:-0}
export RUN_RECEIVER6=${RUN_RECEIVER6:-0}
export RUN_RECEIVER7=${RUN_RECEIVER7:-1}

# Receiver-7 / basis-GRAND settings: bias toward FER, not stage-2 economy.
export GRAND_BGR_LLR_SOURCE=${GRAND_BGR_LLR_SOURCE:-mixed}
export GRAND_BGR_CHECK_COVER_K=${GRAND_BGR_CHECK_COVER_K:-3}
export GRAND_BGR_EPSILON=${GRAND_BGR_EPSILON:-1e-3}
export GRAND_BGR_MAX_WEIGHT=${GRAND_BGR_MAX_WEIGHT:-9}
export GRAND_BGR_MAX_PATTERNS=${GRAND_BGR_MAX_PATTERNS:-160000}
export GRAND_BGR_USE_BOOST=${GRAND_BGR_USE_BOOST:-1}
export GRAND_BGR_BOOST_MAX_WEIGHT=${GRAND_BGR_BOOST_MAX_WEIGHT:-9}
export GRAND_BGR_BOOST_MAX_PATTERNS=${GRAND_BGR_BOOST_MAX_PATTERNS:-500000}
export GRAND_BGR_BATCH_SIZE=${GRAND_BGR_BATCH_SIZE:-256}
export GRAND_BGR_PEEL_RATIO=${GRAND_BGR_PEEL_RATIO:-2.3}
export GRAND_BGR_PEEL_MAX_BITS=${GRAND_BGR_PEEL_MAX_BITS:-88}
export GRAND_BGR_PEEL_DENSE_MAX_VARS=${GRAND_BGR_PEEL_DENSE_MAX_VARS:-40}
export GRAND_BGR_PEEL_MAX_FREE_ENUM=${GRAND_BGR_PEEL_MAX_FREE_ENUM:-12}
export GRAND_BGR_PEEL_EXTRA_LLR_BITS=${GRAND_BGR_PEEL_EXTRA_LLR_BITS:-16}
export GRAND_BGR_RESTART_MAX_CANDIDATES=${GRAND_BGR_RESTART_MAX_CANDIDATES:-24}
export GRAND_BGR_RESTART_ITERS=${GRAND_BGR_RESTART_ITERS:-24}
export GRAND_BGR_RESTART_ALPHA=${GRAND_BGR_RESTART_ALPHA:-0.80}
export GRAND_BGR_RESTART_GAIN=${GRAND_BGR_RESTART_GAIN:-6.0}
export GRAND_BGR_RESTART_DUAL_GAIN=${GRAND_BGR_RESTART_DUAL_GAIN:-9.0}
export GRAND_BGR_RESTART_ABS_FLOOR=${GRAND_BGR_RESTART_ABS_FLOOR:-7.2}
export GRAND_BGR_RATIO=${GRAND_BGR_RATIO:-3.6}
export GRAND_BGR_MAX_BITS=${GRAND_BGR_MAX_BITS:-120}
export GRAND_BGR_MAX_VECTORS=${GRAND_BGR_MAX_VECTORS:-22}
export GRAND_BGR_CORE_VECTORS=${GRAND_BGR_CORE_VECTORS:-14}
export GRAND_BGR_COMBO_MAX=${GRAND_BGR_COMBO_MAX:-3}
export GRAND_BGR_MAX_CANDIDATES=${GRAND_BGR_MAX_CANDIDATES:-192}
export GRAND_BGR_GROUP_MAX_BITS=${GRAND_BGR_GROUP_MAX_BITS:-12}
export GRAND_BGR_WINDOW_MAX=${GRAND_BGR_WINDOW_MAX:-7}
export GRAND_BGR_WINDOW_SPAN=${GRAND_BGR_WINDOW_SPAN:-20}
export GRAND_BGR_DISAGREE_GROUPS=${GRAND_BGR_DISAGREE_GROUPS:-5}
export GRAND_BGR_DISAGREE_CHUNK=${GRAND_BGR_DISAGREE_CHUNK:-6}
export GRAND_BGR_TOP_SINGLETONS=${GRAND_BGR_TOP_SINGLETONS:-10}
export GRAND_BGR_DEBIAS_BLEND=${GRAND_BGR_DEBIAS_BLEND:-0.72}
export GRAND_BGR_DEBIAS_RELAX=${GRAND_BGR_DEBIAS_RELAX:-0.40}

export FORCE_DEFAULTS=${FORCE_DEFAULTS:-1}
if [[ "${FORCE_DEFAULTS}" == "1" ]]; then
  unset SNR_SWEEP LDPC_ITERS STAGE1_ITERS TARGET_FRAME_ERRORS MAX_FRAMES || true
fi

# The run is intentionally narrow and fair: same frames, same stage-1 depth.
export STAGE1_ITERS=${STAGE1_ITERS:-"100"}
export LDPC_ITERS=${LDPC_ITERS:-"100"}
export SNR_SWEEP=${SNR_SWEEP:-"10.0,10.5,11.0,11.5,12.0,12.5,13.0"}
export TARGET_FRAME_ERRORS=${TARGET_FRAME_ERRORS:-120}
export MAX_FRAMES=${MAX_FRAMES:-220000}

SCRIPT=${SCRIPT:-HW3_PARALLEL_Narval_LDPC_GRAND_MS_PATCH.py}
OUT_PREFIX=${OUT_PREFIX:-results/${SLURM_JOB_NAME}_${SLURM_JOB_ID}}

echo "[SBATCH CONFIG] SNR_SWEEP=${SNR_SWEEP}"
echo "[SBATCH CONFIG] LDPC_ITERS=${LDPC_ITERS} STAGE1_ITERS=${STAGE1_ITERS}"
echo "[SBATCH CONFIG] PAIR_DECODER_STREAMS=${PAIR_DECODER_STREAMS} GRAND_RESCUE_SNAPSHOT_ITERS=${GRAND_RESCUE_SNAPSHOT_ITERS}"
echo "[SBATCH CONFIG] CHANNEL=${CHANNEL_NAME} TDL=${SIONNA_TDL_MODEL} DELAY=${SIONNA_TDL_DELAY_SPREAD_S} SPEED=[${SIONNA_TDL_MIN_SPEED},${SIONNA_TDL_MAX_SPEED}] CFO=${SIONNA_CFO_HZ} CSI_MODE=${SIONNA_CSI_MODE}"
echo "[SBATCH CONFIG] RUN_RECEIVER1=${RUN_RECEIVER1} RUN_RECEIVER7=${RUN_RECEIVER7}"
echo "[SBATCH CONFIG] GRAND_BGR_MAX_WEIGHT=${GRAND_BGR_MAX_WEIGHT} GRAND_BGR_MAX_PATTERNS=${GRAND_BGR_MAX_PATTERNS} GRAND_BGR_BOOST_MAX_PATTERNS=${GRAND_BGR_BOOST_MAX_PATTERNS}"
echo "[SBATCH CONFIG] GRAND_BGR_RATIO=${GRAND_BGR_RATIO} GRAND_BGR_MAX_BITS=${GRAND_BGR_MAX_BITS} GRAND_BGR_MAX_VECTORS=${GRAND_BGR_MAX_VECTORS} GRAND_BGR_MAX_CANDIDATES=${GRAND_BGR_MAX_CANDIDATES}"

python -u "$SCRIPT" "$OUT_PREFIX" sionna5g
