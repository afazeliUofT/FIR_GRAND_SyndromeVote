#!/bin/bash

# ===== Slurm resources =====
# NOTE: This is the fair comparison run, close to the current static TDL-A / perfect-CSI setup.
#SBATCH --time=10:00:00
#SBATCH --cpus-per-task=64
#SBATCH --mem=0
#SBATCH --output=logs/%x-%j.out
#SBATCH --error=logs/%x-%j.err

set -euo pipefail

mkdir -p logs results

module --force purge
module load StdEnv/2023 python/3.11 scipy-stack/2024a

VENV_DIR="${VENV_DIR:-$SCRATCH/venvs/grand5g}"
if [[ ! -d "$VENV_DIR" ]]; then
  echo "ERROR: venv not found: $VENV_DIR"
  echo "Create it first (see README / UPGRADE_INSTRUCTIONS)."
  exit 1
fi
source "$VENV_DIR/bin/activate"

export TMPDIR="${TMPDIR:-${SLURM_TMPDIR:-/tmp}}"
export NUMBA_CACHE_DIR="${NUMBA_CACHE_DIR:-$TMPDIR/numba_cache}"
export JOBLIB_TEMP_FOLDER="${JOBLIB_TEMP_FOLDER:-$TMPDIR/joblib}"
mkdir -p "$NUMBA_CACHE_DIR" "$JOBLIB_TEMP_FOLDER"

export USE_GPU=${USE_GPU:-0}
if [[ "${USE_GPU}" != "1" ]]; then
  export CUDA_VISIBLE_DEVICES="-1"
  export TF_CPP_MIN_LOG_LEVEL=${TF_CPP_MIN_LOG_LEVEL:-2}
fi
export TF_INTRA_OP=${TF_INTRA_OP:-1}
export TF_INTER_OP=${TF_INTER_OP:-1}

export MAX_NB_THREADS=${MAX_NB_THREADS:-${SLURM_CPUS_PER_TASK:-64}}
export LDPC_GRAND_NUM_THREADS=${LDPC_GRAND_NUM_THREADS:-${SLURM_CPUS_PER_TASK:-64}}
export SNR_MIN_THREADS_PER_WORKER=${SNR_MIN_THREADS_PER_WORKER:-16}
export PARALLEL_OVER_SNR=${PARALLEL_OVER_SNR:-1}

export OMP_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export MKL_NUM_THREADS=1
export VECLIB_MAXIMUM_THREADS=1
export NUMEXPR_NUM_THREADS=1

export CHANNEL_NAME=SIONNA_TDL

# 5G NR LDPC (Sionna) params
export SIONNA_5G_K=${SIONNA_5G_K:-1024}
export SIONNA_5G_N=${SIONNA_5G_N:-2048}
export SIONNA_5G_QM=${SIONNA_5G_QM:-1}

# ===== Fair / close-to-current channel =====
export SIONNA_TDL_MODEL=${SIONNA_TDL_MODEL:-A}
export SIONNA_TDL_DELAY_SPREAD_S=${SIONNA_TDL_DELAY_SPREAD_S:-3e-7}
export SIONNA_TDL_CARRIER_FREQUENCY_HZ=${SIONNA_TDL_CARRIER_FREQUENCY_HZ:-3.5e9}
export SIONNA_TDL_MIN_SPEED=${SIONNA_TDL_MIN_SPEED:-0.0}
export SIONNA_TDL_MAX_SPEED=${SIONNA_TDL_MAX_SPEED:-0.0}

export SIONNA_OFDM_FFT_SIZE=${SIONNA_OFDM_FFT_SIZE:-256}
export SIONNA_OFDM_SUBCARRIER_SPACING_HZ=${SIONNA_OFDM_SUBCARRIER_SPACING_HZ:-15000}
export SIONNA_CFO_HZ=${SIONNA_CFO_HZ:-0.0}

export SIONNA_CSI_MODE=${SIONNA_CSI_MODE:-perfect}
export SIONNA_CSI_PILOT_STRIDE=${SIONNA_CSI_PILOT_STRIDE:-12}
export SIONNA_CSI_SMOOTH_PILOTS=${SIONNA_CSI_SMOOTH_PILOTS:-1}
export SIONNA_CSI_EST_SNR_DB=${SIONNA_CSI_EST_SNR_DB:-}
export SIONNA_LLR_MAX=${SIONNA_LLR_MAX:-50.0}

# ===== Receiver 1 / 2 / 3 / 4 comparison knobs =====
export GRAND_LLR_SOURCE=${GRAND_LLR_SOURCE:-channel}
export GRAND_MAX_WEIGHT=${GRAND_MAX_WEIGHT:-6}
export GRAND_MAX_PATTERNS=${GRAND_MAX_PATTERNS:-8000}
export GRAND_USE_BOOST=${GRAND_USE_BOOST:-1}
export GRAND_BOOST_MAX_WEIGHT=${GRAND_BOOST_MAX_WEIGHT:-5}
export GRAND_BOOST_MAX_PATTERNS=${GRAND_BOOST_MAX_PATTERNS:-30000}
export GRAND_BATCH_SIZE=${GRAND_BATCH_SIZE:-256}

export RUN_RECEIVER2=${RUN_RECEIVER2:-1}
export GRAND_SV_LLR_SOURCE=${GRAND_SV_LLR_SOURCE:-${GRAND_LLR_SOURCE:-channel}}
export GRAND_SV_CHECK_COVER_K=${GRAND_SV_CHECK_COVER_K:-1}
export GRAND_SV_EPSILON=${GRAND_SV_EPSILON:-1e-3}
export GRAND_SV_MAX_WEIGHT=${GRAND_SV_MAX_WEIGHT:-7}
export GRAND_SV_MAX_PATTERNS=${GRAND_SV_MAX_PATTERNS:-20000}
export GRAND_SV_USE_BOOST=${GRAND_SV_USE_BOOST:-1}
export GRAND_SV_BOOST_MAX_WEIGHT=${GRAND_SV_BOOST_MAX_WEIGHT:-7}
export GRAND_SV_BOOST_MAX_PATTERNS=${GRAND_SV_BOOST_MAX_PATTERNS:-120000}
export GRAND_SV_BATCH_SIZE=${GRAND_SV_BATCH_SIZE:-${GRAND_BATCH_SIZE:-256}}

export RUN_RECEIVER3=${RUN_RECEIVER3:-1}
export GRAND_PTG_LLR_SOURCE=${GRAND_PTG_LLR_SOURCE:-mixed}
export GRAND_PTG_CHECK_COVER_K=${GRAND_PTG_CHECK_COVER_K:-2}
export GRAND_PTG_EPSILON=${GRAND_PTG_EPSILON:-1e-3}
export GRAND_PTG_MAX_WEIGHT=${GRAND_PTG_MAX_WEIGHT:-8}
export GRAND_PTG_MAX_PATTERNS=${GRAND_PTG_MAX_PATTERNS:-40000}
export GRAND_PTG_USE_BOOST=${GRAND_PTG_USE_BOOST:-1}
export GRAND_PTG_BOOST_MAX_WEIGHT=${GRAND_PTG_BOOST_MAX_WEIGHT:-8}
export GRAND_PTG_BOOST_MAX_PATTERNS=${GRAND_PTG_BOOST_MAX_PATTERNS:-250000}
export GRAND_PTG_BATCH_SIZE=${GRAND_PTG_BATCH_SIZE:-${GRAND_BATCH_SIZE:-256}}
export GRAND_PTG_PEEL_RATIO=${GRAND_PTG_PEEL_RATIO:-1.85}
export GRAND_PTG_PEEL_MAX_BITS=${GRAND_PTG_PEEL_MAX_BITS:-56}
export GRAND_PTG_PEEL_DENSE_MAX_VARS=${GRAND_PTG_PEEL_DENSE_MAX_VARS:-32}
export GRAND_PTG_PEEL_MAX_FREE_ENUM=${GRAND_PTG_PEEL_MAX_FREE_ENUM:-12}
export GRAND_PTG_PEEL_EXTRA_LLR_BITS=${GRAND_PTG_PEEL_EXTRA_LLR_BITS:-10}

export RUN_RECEIVER4=${RUN_RECEIVER4:-1}
export GRAND_CTG_LLR_SOURCE=${GRAND_CTG_LLR_SOURCE:-mixed}
export GRAND_CTG_CHECK_COVER_K=${GRAND_CTG_CHECK_COVER_K:-2}
export GRAND_CTG_EPSILON=${GRAND_CTG_EPSILON:-1e-3}
export GRAND_CTG_MAX_WEIGHT=${GRAND_CTG_MAX_WEIGHT:-8}
export GRAND_CTG_MAX_PATTERNS=${GRAND_CTG_MAX_PATTERNS:-40000}
export GRAND_CTG_USE_BOOST=${GRAND_CTG_USE_BOOST:-1}
export GRAND_CTG_BOOST_MAX_WEIGHT=${GRAND_CTG_BOOST_MAX_WEIGHT:-8}
export GRAND_CTG_BOOST_MAX_PATTERNS=${GRAND_CTG_BOOST_MAX_PATTERNS:-250000}
export GRAND_CTG_BATCH_SIZE=${GRAND_CTG_BATCH_SIZE:-${GRAND_BATCH_SIZE:-256}}
export GRAND_CTG_PEEL_RATIO=${GRAND_CTG_PEEL_RATIO:-1.9}
export GRAND_CTG_PEEL_MAX_BITS=${GRAND_CTG_PEEL_MAX_BITS:-60}
export GRAND_CTG_PEEL_DENSE_MAX_VARS=${GRAND_CTG_PEEL_DENSE_MAX_VARS:-32}
export GRAND_CTG_PEEL_MAX_FREE_ENUM=${GRAND_CTG_PEEL_MAX_FREE_ENUM:-12}
export GRAND_CTG_PEEL_EXTRA_LLR_BITS=${GRAND_CTG_PEEL_EXTRA_LLR_BITS:-10}
export GRAND_CTG_CHASE_RATIO=${GRAND_CTG_CHASE_RATIO:-2.3}
export GRAND_CTG_CHASE_MAX_BITS=${GRAND_CTG_CHASE_MAX_BITS:-64}
export GRAND_CTG_CORE_MAX_BITS=${GRAND_CTG_CORE_MAX_BITS:-14}
export GRAND_CTG_CORE_MAX_WEIGHT=${GRAND_CTG_CORE_MAX_WEIGHT:-3}
export GRAND_CTG_MAX_CANDIDATES=${GRAND_CTG_MAX_CANDIDATES:-96}
export GRAND_CTG_LDPC_EXTRA_ITERS=${GRAND_CTG_LDPC_EXTRA_ITERS:-6}
export GRAND_CTG_LLR_GAIN=${GRAND_CTG_LLR_GAIN:-3.2}
export GRAND_CTG_LLR_ABS_FLOOR=${GRAND_CTG_LLR_ABS_FLOOR:-5.0}

# ===== Receiver 5 / OSD + anchored restart =====
export RUN_RECEIVER5=${RUN_RECEIVER5:-1}
export GRAND_OSD_LLR_SOURCE=${GRAND_OSD_LLR_SOURCE:-mixed}
export GRAND_OSD_CHECK_COVER_K=${GRAND_OSD_CHECK_COVER_K:-3}
export GRAND_OSD_EPSILON=${GRAND_OSD_EPSILON:-1e-3}
export GRAND_OSD_MAX_WEIGHT=${GRAND_OSD_MAX_WEIGHT:-8}
export GRAND_OSD_MAX_PATTERNS=${GRAND_OSD_MAX_PATTERNS:-80000}
export GRAND_OSD_USE_BOOST=${GRAND_OSD_USE_BOOST:-1}
export GRAND_OSD_BOOST_MAX_WEIGHT=${GRAND_OSD_BOOST_MAX_WEIGHT:-8}
export GRAND_OSD_BOOST_MAX_PATTERNS=${GRAND_OSD_BOOST_MAX_PATTERNS:-400000}
export GRAND_OSD_BATCH_SIZE=${GRAND_OSD_BATCH_SIZE:-${GRAND_BATCH_SIZE:-256}}
export GRAND_OSD_PEEL_RATIO=${GRAND_OSD_PEEL_RATIO:-2.0}
export GRAND_OSD_PEEL_MAX_BITS=${GRAND_OSD_PEEL_MAX_BITS:-64}
export GRAND_OSD_PEEL_DENSE_MAX_VARS=${GRAND_OSD_PEEL_DENSE_MAX_VARS:-32}
export GRAND_OSD_PEEL_MAX_FREE_ENUM=${GRAND_OSD_PEEL_MAX_FREE_ENUM:-12}
export GRAND_OSD_PEEL_EXTRA_LLR_BITS=${GRAND_OSD_PEEL_EXTRA_LLR_BITS:-10}
export GRAND_OSD_RATIO=${GRAND_OSD_RATIO:-3.0}
export GRAND_OSD_MAX_BITS=${GRAND_OSD_MAX_BITS:-80}
export GRAND_OSD_ORDER=${GRAND_OSD_ORDER:-2}
export GRAND_OSD_ENUM_MAX_BITS=${GRAND_OSD_ENUM_MAX_BITS:-20}
export GRAND_OSD_MAX_CANDIDATES=${GRAND_OSD_MAX_CANDIDATES:-160}
export GRAND_OSD_DISAGREEMENT_BITS=${GRAND_OSD_DISAGREEMENT_BITS:-8}
export GRAND_OSD_RESTART_MAX_CANDIDATES=${GRAND_OSD_RESTART_MAX_CANDIDATES:-20}
export GRAND_OSD_RESTART_ITERS=${GRAND_OSD_RESTART_ITERS:-14}
export GRAND_OSD_RESTART_ALPHA=${GRAND_OSD_RESTART_ALPHA:-0.78}
export GRAND_OSD_RESTART_GAIN=${GRAND_OSD_RESTART_GAIN:-4.2}
export GRAND_OSD_RESTART_DUAL_GAIN=${GRAND_OSD_RESTART_DUAL_GAIN:-6.0}
export GRAND_OSD_RESTART_ABS_FLOOR=${GRAND_OSD_RESTART_ABS_FLOOR:-6.0}
export GRAND_OSD_RESTART_ANCHOR_ALL=${GRAND_OSD_RESTART_ANCHOR_ALL:-0}

# ===== Receiver 6 / soft-anchor + full-graph restart =====
export RUN_RECEIVER6=${RUN_RECEIVER6:-1}
export GRAND_AHR_LLR_SOURCE=${GRAND_AHR_LLR_SOURCE:-mixed}
export GRAND_AHR_CHECK_COVER_K=${GRAND_AHR_CHECK_COVER_K:-3}
export GRAND_AHR_EPSILON=${GRAND_AHR_EPSILON:-1e-3}
export GRAND_AHR_MAX_WEIGHT=${GRAND_AHR_MAX_WEIGHT:-8}
export GRAND_AHR_MAX_PATTERNS=${GRAND_AHR_MAX_PATTERNS:-100000}
export GRAND_AHR_USE_BOOST=${GRAND_AHR_USE_BOOST:-1}
export GRAND_AHR_BOOST_MAX_WEIGHT=${GRAND_AHR_BOOST_MAX_WEIGHT:-8}
export GRAND_AHR_BOOST_MAX_PATTERNS=${GRAND_AHR_BOOST_MAX_PATTERNS:-500000}
export GRAND_AHR_BATCH_SIZE=${GRAND_AHR_BATCH_SIZE:-${GRAND_BATCH_SIZE:-256}}
export GRAND_AHR_PEEL_RATIO=${GRAND_AHR_PEEL_RATIO:-2.1}
export GRAND_AHR_PEEL_MAX_BITS=${GRAND_AHR_PEEL_MAX_BITS:-72}
export GRAND_AHR_PEEL_DENSE_MAX_VARS=${GRAND_AHR_PEEL_DENSE_MAX_VARS:-34}
export GRAND_AHR_PEEL_MAX_FREE_ENUM=${GRAND_AHR_PEEL_MAX_FREE_ENUM:-12}
export GRAND_AHR_PEEL_EXTRA_LLR_BITS=${GRAND_AHR_PEEL_EXTRA_LLR_BITS:-12}
export GRAND_AHR_RATIO=${GRAND_AHR_RATIO:-3.1}
export GRAND_AHR_MAX_BITS=${GRAND_AHR_MAX_BITS:-96}
export GRAND_AHR_CORE_MAX_BITS=${GRAND_AHR_CORE_MAX_BITS:-14}
export GRAND_AHR_CORE_MAX_WEIGHT=${GRAND_AHR_CORE_MAX_WEIGHT:-3}
export GRAND_AHR_MAX_CANDIDATES=${GRAND_AHR_MAX_CANDIDATES:-128}
export GRAND_AHR_SAT_PENALTY=${GRAND_AHR_SAT_PENALTY:-0.40}
export GRAND_AHR_LLR_WEIGHT=${GRAND_AHR_LLR_WEIGHT:-0.10}
export GRAND_AHR_RESTART_MAX_CANDIDATES=${GRAND_AHR_RESTART_MAX_CANDIDATES:-24}
export GRAND_AHR_RESTART_ITERS=${GRAND_AHR_RESTART_ITERS:-16}
export GRAND_AHR_RESTART_ALPHA=${GRAND_AHR_RESTART_ALPHA:-0.80}
export GRAND_AHR_RESTART_GAIN=${GRAND_AHR_RESTART_GAIN:-4.8}
export GRAND_AHR_RESTART_DUAL_GAIN=${GRAND_AHR_RESTART_DUAL_GAIN:-7.5}
export GRAND_AHR_RESTART_ABS_FLOOR=${GRAND_AHR_RESTART_ABS_FLOOR:-6.5}
export GRAND_AHR_RESTART_ANCHOR_ALL=${GRAND_AHR_RESTART_ANCHOR_ALL:-1}

# ===== Sweep + Monte-Carlo limits =====
export FORCE_DEFAULTS=${FORCE_DEFAULTS:-1}
if [[ "${FORCE_DEFAULTS}" == "1" ]]; then
  unset SNR_SWEEP LDPC_ITERS STAGE1_ITERS TARGET_FRAME_ERRORS MAX_FRAMES || true
fi

export STAGE1_ITERS=${STAGE1_ITERS:-"4,8,15"}
export LDPC_ITERS=${LDPC_ITERS:-"4,8,15,20,100"}
# Focus the fair sweep where stage-2 still has meaningful headroom.
export SNR_SWEEP=${SNR_SWEEP:-"7.0,7.5,8.0,8.5,9.0,9.5,10.0"}
export TARGET_FRAME_ERRORS=${TARGET_FRAME_ERRORS:-250}
export MAX_FRAMES=${MAX_FRAMES:-250000}

echo "[SBATCH CONFIG] FORCE_DEFAULTS=${FORCE_DEFAULTS}"
echo "[SBATCH CONFIG] SNR_SWEEP=${SNR_SWEEP}"
echo "[SBATCH CONFIG] LDPC_ITERS=${LDPC_ITERS}"
echo "[SBATCH CONFIG] STAGE1_ITERS=${STAGE1_ITERS}"
echo "[SBATCH CONFIG] TARGET_FRAME_ERRORS=${TARGET_FRAME_ERRORS}  MAX_FRAMES=${MAX_FRAMES}"
echo "[SBATCH CONFIG] CHANNEL=${CHANNEL_NAME} TDL=${SIONNA_TDL_MODEL} DELAY=${SIONNA_TDL_DELAY_SPREAD_S} SPEED=[${SIONNA_TDL_MIN_SPEED},${SIONNA_TDL_MAX_SPEED}] CFO=${SIONNA_CFO_HZ}"
echo "[SBATCH CONFIG] CSI_MODE=${SIONNA_CSI_MODE} RUN_RECEIVER2=${RUN_RECEIVER2} RUN_RECEIVER3=${RUN_RECEIVER3} RUN_RECEIVER4=${RUN_RECEIVER4} RUN_RECEIVER5=${RUN_RECEIVER5} RUN_RECEIVER6=${RUN_RECEIVER6}"
echo "[SBATCH CONFIG] GRAND_OSD_RATIO=${GRAND_OSD_RATIO} GRAND_OSD_MAX_BITS=${GRAND_OSD_MAX_BITS} GRAND_OSD_ORDER=${GRAND_OSD_ORDER} GRAND_OSD_ENUM_MAX_BITS=${GRAND_OSD_ENUM_MAX_BITS}"
echo "[SBATCH CONFIG] GRAND_OSD_MAX_CANDIDATES=${GRAND_OSD_MAX_CANDIDATES} GRAND_OSD_RESTART_MAX_CANDIDATES=${GRAND_OSD_RESTART_MAX_CANDIDATES} GRAND_OSD_RESTART_ITERS=${GRAND_OSD_RESTART_ITERS}"
echo "[SBATCH CONFIG] GRAND_AHR_RATIO=${GRAND_AHR_RATIO} GRAND_AHR_MAX_BITS=${GRAND_AHR_MAX_BITS} GRAND_AHR_CORE_MAX_BITS=${GRAND_AHR_CORE_MAX_BITS} GRAND_AHR_MAX_CANDIDATES=${GRAND_AHR_MAX_CANDIDATES}"
echo "[SBATCH CONFIG] GRAND_AHR_RESTART_MAX_CANDIDATES=${GRAND_AHR_RESTART_MAX_CANDIDATES} GRAND_AHR_RESTART_ITERS=${GRAND_AHR_RESTART_ITERS} GRAND_AHR_RESTART_GAIN=${GRAND_AHR_RESTART_GAIN} GRAND_AHR_RESTART_DUAL_GAIN=${GRAND_AHR_RESTART_DUAL_GAIN}"

SCRIPT=${SCRIPT:-HW3_PARALLEL_Narval_LDPC_GRAND_MS_PATCH.py}
OUT_PREFIX=${OUT_PREFIX:-results/${SLURM_JOB_NAME}_${SLURM_JOB_ID}}

python -u "$SCRIPT" "$OUT_PREFIX" sionna5g
