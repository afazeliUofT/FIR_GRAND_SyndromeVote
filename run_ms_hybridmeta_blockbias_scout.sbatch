#!/bin/bash
#SBATCH --time=12:00:00
#SBATCH --cpus-per-task=64
#SBATCH --mem=0
#SBATCH --output=logs/%x-%j.out
#SBATCH --error=logs/%x-%j.err

set -euo pipefail
mkdir -p logs results

module --force purge
module load StdEnv/2023 python/3.11 scipy-stack/2024a

VENV_DIR="${VENV_DIR:-$SCRATCH/venvs/grand5g}"
if [[ ! -d "$VENV_DIR" ]]; then
  echo "ERROR: venv not found: $VENV_DIR"
  exit 1
fi
source "$VENV_DIR/bin/activate"

export TMPDIR="${TMPDIR:-${SLURM_TMPDIR:-/tmp}}"
export NUMBA_CACHE_DIR="${NUMBA_CACHE_DIR:-$TMPDIR/numba_cache}"
export JOBLIB_TEMP_FOLDER="${JOBLIB_TEMP_FOLDER:-$TMPDIR/joblib}"
mkdir -p "$NUMBA_CACHE_DIR" "$JOBLIB_TEMP_FOLDER"

export USE_GPU=${USE_GPU:-0}
if [[ "${USE_GPU}" != "1" ]]; then
  export CUDA_VISIBLE_DEVICES="-1"
  export TF_CPP_MIN_LOG_LEVEL=${TF_CPP_MIN_LOG_LEVEL:-2}
fi

export TF_INTRA_OP=${TF_INTRA_OP:-1}
export TF_INTER_OP=${TF_INTER_OP:-1}
export MAX_NB_THREADS=${MAX_NB_THREADS:-${SLURM_CPUS_PER_TASK:-64}}
export LDPC_GRAND_NUM_THREADS=${LDPC_GRAND_NUM_THREADS:-${SLURM_CPUS_PER_TASK:-64}}
export SNR_MIN_THREADS_PER_WORKER=${SNR_MIN_THREADS_PER_WORKER:-16}
export PARALLEL_OVER_SNR=${PARALLEL_OVER_SNR:-1}
export PAIR_DECODER_STREAMS=${PAIR_DECODER_STREAMS:-1}
export OMP_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export MKL_NUM_THREADS=1
export VECLIB_MAXIMUM_THREADS=1
export NUMEXPR_NUM_THREADS=1

export CHANNEL_NAME=SIONNA_TDL
export SIONNA_5G_K=${SIONNA_5G_K:-1024}
export SIONNA_5G_N=${SIONNA_5G_N:-2048}
export SIONNA_5G_QM=${SIONNA_5G_QM:-1}

# Stronger block-bias / local-CSI-error regime intended to favor anchored restart hybrids.
export SIONNA_TDL_MODEL=${SIONNA_TDL_MODEL:-B}
export SIONNA_TDL_DELAY_SPREAD_S=${SIONNA_TDL_DELAY_SPREAD_S:-5e-7}
export SIONNA_TDL_CARRIER_FREQUENCY_HZ=${SIONNA_TDL_CARRIER_FREQUENCY_HZ:-3.5e9}
export SIONNA_TDL_MIN_SPEED=${SIONNA_TDL_MIN_SPEED:-0.5}
export SIONNA_TDL_MAX_SPEED=${SIONNA_TDL_MAX_SPEED:-2.0}
export SIONNA_OFDM_FFT_SIZE=${SIONNA_OFDM_FFT_SIZE:-512}
export SIONNA_OFDM_SUBCARRIER_SPACING_HZ=${SIONNA_OFDM_SUBCARRIER_SPACING_HZ:-15000}
export SIONNA_CFO_HZ=${SIONNA_CFO_HZ:-40.0}
export SIONNA_CSI_MODE=${SIONNA_CSI_MODE:-nr_imperfect}
export SIONNA_CSI_PILOT_STRIDE=${SIONNA_CSI_PILOT_STRIDE:-32}
export SIONNA_CSI_SMOOTH_PILOTS=${SIONNA_CSI_SMOOTH_PILOTS:-1}
export SIONNA_CSI_EST_SNR_DB=${SIONNA_CSI_EST_SNR_DB:-18}
export SIONNA_CSI_PHASE_DRIFT_STD_DEG=${SIONNA_CSI_PHASE_DRIFT_STD_DEG:-1.2}
export SIONNA_CSI_AMP_RIPPLE_DB=${SIONNA_CSI_AMP_RIPPLE_DB:-0.9}
export SIONNA_CSI_DELAY_BIAS_NS=${SIONNA_CSI_DELAY_BIAS_NS:-10.0}
export SIONNA_CSI_BLOCK_SC=${SIONNA_CSI_BLOCK_SC:-48}
export SIONNA_LLR_MAX=${SIONNA_LLR_MAX:-50.0}

export FORCE_DEFAULTS=1
export SNR_SWEEP=${SNR_SWEEP:-8.5,9.0,9.5,10.0,10.5,11.0,11.5,12.0,12.5,13.0,13.5}
export LDPC_ITERS=${LDPC_ITERS:-8,12,15}
export STAGE1_ITERS=${STAGE1_ITERS:-8,12,15}
export TARGET_FRAME_ERRORS=${TARGET_FRAME_ERRORS:-140}
export MAX_FRAMES=${MAX_FRAMES:-260000}
export RESULTS_DIR=${RESULTS_DIR:-results/${SLURM_JOB_NAME}_${SLURM_JOB_ID}}

export RUN_RECEIVER1=0
export RUN_RECEIVER2=0
export RUN_RECEIVER3=0
export RUN_RECEIVER4=0
export RUN_RECEIVER5=0
export RUN_RECEIVER6=1
export RUN_RECEIVER7=0
export RUN_RECEIVER8=1

# Early rescue only: current evidence says late snapshots mostly waste work.
export GRAND_RESCUE_SNAPSHOT_ITERS=${GRAND_RESCUE_SNAPSHOT_ITERS:-4,8,12,15}

# Receiver-6/AHR tuning.
export GRAND_AHR_MAX_PATTERNS=${GRAND_AHR_MAX_PATTERNS:-120000}
export GRAND_AHR_BOOST_MAX_PATTERNS=${GRAND_AHR_BOOST_MAX_PATTERNS:-800000}
export GRAND_AHR_RATIO=${GRAND_AHR_RATIO:-3.4}
export GRAND_AHR_MAX_CANDIDATES=${GRAND_AHR_MAX_CANDIDATES:-160}
export GRAND_AHR_RESTART_MAX_CANDIDATES=${GRAND_AHR_RESTART_MAX_CANDIDATES:-28}
export GRAND_AHR_RESTART_ITERS=${GRAND_AHR_RESTART_ITERS:-22}
export GRAND_AHR_RESTART_GAIN=${GRAND_AHR_RESTART_GAIN:-5.2}
export GRAND_AHR_RESTART_DUAL_GAIN=${GRAND_AHR_RESTART_DUAL_GAIN:-7.6}

# Receiver-8/meta tuning.
export GRAND_META_USE_FALLBACK=1
export GRAND_META_MAX_PATTERNS=${GRAND_META_MAX_PATTERNS:-160000}
export GRAND_META_BOOST_MAX_PATTERNS=${GRAND_META_BOOST_MAX_PATTERNS:-1200000}
export GRAND_META_RATIO=${GRAND_META_RATIO:-4.0}
export GRAND_META_MAX_CANDIDATES=${GRAND_META_MAX_CANDIDATES:-192}
export GRAND_META_RESTART_MAX_CANDIDATES=${GRAND_META_RESTART_MAX_CANDIDATES:-32}
export GRAND_META_RESTART_ITERS=${GRAND_META_RESTART_ITERS:-24}
export GRAND_META_RESTART_GAIN=${GRAND_META_RESTART_GAIN:-5.6}
export GRAND_META_RESTART_DUAL_GAIN=${GRAND_META_RESTART_DUAL_GAIN:-8.0}
export GRAND_META_CORE_MAX_BITS=${GRAND_META_CORE_MAX_BITS:-16}
export GRAND_META_PEEL_RATIO=${GRAND_META_PEEL_RATIO:-2.4}

# Fallback Receiver-7 kept available inside Receiver-8 only.
export GRAND_BGR_MAX_PATTERNS=${GRAND_BGR_MAX_PATTERNS:-100000}
export GRAND_BGR_BOOST_MAX_PATTERNS=${GRAND_BGR_BOOST_MAX_PATTERNS:-300000}
export GRAND_BGR_RATIO=${GRAND_BGR_RATIO:-3.0}
export GRAND_BGR_MAX_CANDIDATES=${GRAND_BGR_MAX_CANDIDATES:-128}

printf '[SBATCH CONFIG] SNR_SWEEP=%s\n' "$SNR_SWEEP"
printf '[SBATCH CONFIG] LDPC_ITERS=%s STAGE1_ITERS=%s\n' "$LDPC_ITERS" "$STAGE1_ITERS"
printf '[SBATCH CONFIG] PAIR_DECODER_STREAMS=%s GRAND_RESCUE_SNAPSHOT_ITERS=%s\n' "$PAIR_DECODER_STREAMS" "$GRAND_RESCUE_SNAPSHOT_ITERS"
printf '[SBATCH CONFIG] CHANNEL=%s TDL=%s DELAY=%s SPEED=[%s,%s] CFO=%s CSI_MODE=%s\n' \
  "$CHANNEL_NAME" "$SIONNA_TDL_MODEL" "$SIONNA_TDL_DELAY_SPREAD_S" "$SIONNA_TDL_MIN_SPEED" "$SIONNA_TDL_MAX_SPEED" "$SIONNA_CFO_HZ" "$SIONNA_CSI_MODE"
printf '[SBATCH CONFIG] RUN_RECEIVER6=%s RUN_RECEIVER8=%s\n' "$RUN_RECEIVER6" "$RUN_RECEIVER8"

python HW3_PARALLEL_Narval_LDPC_GRAND_MS_PATCH.py "$RESULTS_DIR" sionna5g
