#!/bin/bash
#SBATCH --job-name=FIR_GRAND_R4R
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=64
#SBATCH --mem=0
#SBATCH --time=8:00:00
#SBATCH --output=logs/%x-%j.out
#SBATCH --error=logs/%x-%j.err
#SBATCH --account=def-rsadve

set -euo pipefail

REPO_ROOT="${REPO_ROOT:-/home/rsadve1/scratch/FIR_GRAND_SyndromeVote}"
cd "$REPO_ROOT"

mkdir -p logs
mkdir -p results

echo "[PWD] $(pwd)"
echo "[HOST] $(hostname)"
echo "[DATE] $(date)"
echo "[SLURM_JOB_ID] ${SLURM_JOB_ID:-manual}"
echo "[SLURM_CPUS_PER_TASK] ${SLURM_CPUS_PER_TASK:-unset}"

# Activate your FIR environment here if needed.
# Example:
# source ~/scratch/FIR/bin/activate
# or
# source ~/venvs/fir/bin/activate

export PYTHONUNBUFFERED=1

# Threading / TensorFlow / Numba hygiene
export USE_GPU=${USE_GPU:-0}
export OMP_NUM_THREADS=${OMP_NUM_THREADS:-1}
export TF_INTRA_OP=${TF_INTRA_OP:-1}
export TF_INTER_OP=${TF_INTER_OP:-1}
export LDPC_GRAND_NUM_THREADS=${LDPC_GRAND_NUM_THREADS:-${SLURM_CPUS_PER_TASK:-64}}

# Experiment entry point
export RUN_EXPERIMENTS=${RUN_EXPERIMENTS:-1}
export RUN_CODES=${RUN_CODES:-sionna5g}
export RESULTS_DIR=${RESULTS_DIR:-"$REPO_ROOT/results/run_ms.sbatch_${SLURM_JOB_ID:-manual}"}

# SNR-parallel plan
export PARALLEL_OVER_SNR=${PARALLEL_OVER_SNR:-1}
export SNR_MIN_THREADS_PER_WORKER=${SNR_MIN_THREADS_PER_WORKER:-8}
export JOBLIB_BACKEND=${JOBLIB_BACKEND:-loky}

# RNG / sweep
export RNG_SEED_GLOBAL=${RNG_SEED_GLOBAL:-12345}
export INTERLEAVER_SEED=${INTERLEAVER_SEED:-2025}
export STAGE1_ITERS=${STAGE1_ITERS:-"4,8,15"}
export LDPC_ITERS=${LDPC_ITERS:-"4,8,15,20,100"}
export SNR_SWEEP=${SNR_SWEEP:-"7,7.5,8,8.5,9,9.5,10,10.5,11"}
export TARGET_FRAME_ERRORS=${TARGET_FRAME_ERRORS:-200}
export MAX_FRAMES=${MAX_FRAMES:-200000}

# 5G NR / Sionna path
export CHANNEL_NAME=${CHANNEL_NAME:-SIONNA_TDL}
export SIONNA_5G_K=${SIONNA_5G_K:-1024}
export SIONNA_5G_N=${SIONNA_5G_N:-2048}
export SIONNA_5G_QM=${SIONNA_5G_QM:-1}
export SIONNA_LLR_MAX=${SIONNA_LLR_MAX:-50.0}
export SIONNA_TDL_MODEL=${SIONNA_TDL_MODEL:-A}
export SIONNA_TDL_DELAY_SPREAD_S=${SIONNA_TDL_DELAY_SPREAD_S:-3e-7}
export SIONNA_TDL_CARRIER_FREQUENCY_HZ=${SIONNA_TDL_CARRIER_FREQUENCY_HZ:-3.5e9}
export SIONNA_TDL_MIN_SPEED=${SIONNA_TDL_MIN_SPEED:-0.0}
export SIONNA_TDL_MAX_SPEED=${SIONNA_TDL_MAX_SPEED:-0.0}

# =========================
# Receiver 1 (baseline)
# =========================
export GRAND_LLR_SOURCE=${GRAND_LLR_SOURCE:-channel}
export GRAND_MAX_WEIGHT=${GRAND_MAX_WEIGHT:-5}
export GRAND_MAX_PATTERNS=${GRAND_MAX_PATTERNS:-5000}
export GRAND_OVERGEN=${GRAND_OVERGEN:-1.02}
export GRAND_BATCH_SIZE=${GRAND_BATCH_SIZE:-256}
export GRAND_USE_BOOST=${GRAND_USE_BOOST:-1}
export GRAND_BOOST_MAX_WEIGHT=${GRAND_BOOST_MAX_WEIGHT:-5}
export GRAND_BOOST_MAX_PATTERNS=${GRAND_BOOST_MAX_PATTERNS:-15000}
export GRAND_BOOST_OVERGEN=${GRAND_BOOST_OVERGEN:-1.02}

# =========================
# Receiver 2 (syndrome vote)
# =========================
export RUN_RECEIVER2=${RUN_RECEIVER2:-1}
export GRAND_SV_LLR_SOURCE=${GRAND_SV_LLR_SOURCE:-${GRAND_LLR_SOURCE:-channel}}
export GRAND_SV_CHECK_COVER_K=${GRAND_SV_CHECK_COVER_K:-1}
export GRAND_SV_EPSILON=${GRAND_SV_EPSILON:-1e-3}
export GRAND_SV_MAX_WEIGHT=${GRAND_SV_MAX_WEIGHT:-7}
export GRAND_SV_MAX_PATTERNS=${GRAND_SV_MAX_PATTERNS:-20000}
export GRAND_SV_BATCH_SIZE=${GRAND_SV_BATCH_SIZE:-${GRAND_BATCH_SIZE:-256}}
export GRAND_SV_USE_BOOST=${GRAND_SV_USE_BOOST:-1}
export GRAND_SV_BOOST_MAX_WEIGHT=${GRAND_SV_BOOST_MAX_WEIGHT:-7}
export GRAND_SV_BOOST_MAX_PATTERNS=${GRAND_SV_BOOST_MAX_PATTERNS:-120000}

# =========================
# Receiver 3+ (current strongest exact path)
# =========================
export RUN_RECEIVER3=${RUN_RECEIVER3:-1}
export GRAND_PTG_LLR_SOURCE=${GRAND_PTG_LLR_SOURCE:-mixed}
export GRAND_PTG_CHECK_COVER_K=${GRAND_PTG_CHECK_COVER_K:-2}
export GRAND_PTG_EPSILON=${GRAND_PTG_EPSILON:-1e-3}
export GRAND_PTG_MAX_WEIGHT=${GRAND_PTG_MAX_WEIGHT:-8}
export GRAND_PTG_MAX_PATTERNS=${GRAND_PTG_MAX_PATTERNS:-40000}
export GRAND_PTG_BATCH_SIZE=${GRAND_PTG_BATCH_SIZE:-${GRAND_BATCH_SIZE:-256}}
export GRAND_PTG_PEEL_RATIO=${GRAND_PTG_PEEL_RATIO:-1.75}
export GRAND_PTG_PEEL_MAX_BITS=${GRAND_PTG_PEEL_MAX_BITS:-48}
export GRAND_PTG_PEEL_DENSE_MAX_VARS=${GRAND_PTG_PEEL_DENSE_MAX_VARS:-28}
export GRAND_PTG_PEEL_MAX_FREE_ENUM=${GRAND_PTG_PEEL_MAX_FREE_ENUM:-12}
export GRAND_PTG_PEEL_EXTRA_LLR_BITS=${GRAND_PTG_PEEL_EXTRA_LLR_BITS:-8}
export GRAND_PTG_USE_BOOST=${GRAND_PTG_USE_BOOST:-1}
export GRAND_PTG_BOOST_MAX_WEIGHT=${GRAND_PTG_BOOST_MAX_WEIGHT:-8}
export GRAND_PTG_BOOST_MAX_PATTERNS=${GRAND_PTG_BOOST_MAX_PATTERNS:-250000}

# =========================
# Receiver 4R
# =========================
export RUN_RECEIVER4=${RUN_RECEIVER4:-1}

# Exact stage before restart beam
export GRAND_RR_LLR_SOURCE=${GRAND_RR_LLR_SOURCE:-mixed}
export GRAND_RR_CHECK_COVER_K=${GRAND_RR_CHECK_COVER_K:-2}
export GRAND_RR_EPSILON=${GRAND_RR_EPSILON:-1e-3}
export GRAND_RR_MAX_WEIGHT=${GRAND_RR_MAX_WEIGHT:-8}
export GRAND_RR_MAX_PATTERNS=${GRAND_RR_MAX_PATTERNS:-50000}
export GRAND_RR_BATCH_SIZE=${GRAND_RR_BATCH_SIZE:-${GRAND_BATCH_SIZE:-256}}

# Exact Receiver-3+ front-end strength
export GRAND_RR_PEEL_RATIO=${GRAND_RR_PEEL_RATIO:-1.90}
export GRAND_RR_PEEL_MAX_BITS=${GRAND_RR_PEEL_MAX_BITS:-56}
export GRAND_RR_PEEL_DENSE_MAX_VARS=${GRAND_RR_PEEL_DENSE_MAX_VARS:-32}
export GRAND_RR_PEEL_MAX_FREE_ENUM=${GRAND_RR_PEEL_MAX_FREE_ENUM:-12}
export GRAND_RR_PEEL_EXTRA_LLR_BITS=${GRAND_RR_PEEL_EXTRA_LLR_BITS:-10}

# Multi-snapshot + beam-restart knobs
export GRAND_RR_SNAPSHOTS=${GRAND_RR_SNAPSHOTS:-"8,15,4"}
export GRAND_RR_RESTART_SEED_LLR=${GRAND_RR_RESTART_SEED_LLR:-mixed}
export GRAND_RR_RESTART_TOP_BITS=${GRAND_RR_RESTART_TOP_BITS:-10}
export GRAND_RR_RESTART_MAX_ORDER=${GRAND_RR_RESTART_MAX_ORDER:-3}
export GRAND_RR_RESTART_MAX_CANDIDATES=${GRAND_RR_RESTART_MAX_CANDIDATES:-8}
export GRAND_RR_RESTART_MAX_CANDIDATES_PER_SNAPSHOT=${GRAND_RR_RESTART_MAX_CANDIDATES_PER_SNAPSHOT:-4}
export GRAND_RR_RESTART_CANDIDATE_POOL_SIZE=${GRAND_RR_RESTART_CANDIDATE_POOL_SIZE:-24}
export GRAND_RR_RESTART_BIAS_ALPHA=${GRAND_RR_RESTART_BIAS_ALPHA:-1.35}
export GRAND_RR_RESTART_BIAS_OFFSET=${GRAND_RR_RESTART_BIAS_OFFSET:-0.75}
export GRAND_RR_RESTART_FORCE_ABS=${GRAND_RR_RESTART_FORCE_ABS:-8.0}
export GRAND_RR_EXTRA_LDPC_ITERS=${GRAND_RR_EXTRA_LDPC_ITERS:-8}
export GRAND_RR_LDPC_ALPHA=${GRAND_RR_LDPC_ALPHA:-0.8}

# Boost path for hard failures
export GRAND_RR_USE_BOOST=${GRAND_RR_USE_BOOST:-1}
export GRAND_RR_BOOST_LLR_SOURCE=${GRAND_RR_BOOST_LLR_SOURCE:-${GRAND_RR_LLR_SOURCE}}
export GRAND_RR_BOOST_CHECK_COVER_K=${GRAND_RR_BOOST_CHECK_COVER_K:-${GRAND_RR_CHECK_COVER_K}}
export GRAND_RR_BOOST_EPSILON=${GRAND_RR_BOOST_EPSILON:-${GRAND_RR_EPSILON}}
export GRAND_RR_BOOST_MAX_WEIGHT=${GRAND_RR_BOOST_MAX_WEIGHT:-8}
export GRAND_RR_BOOST_MAX_PATTERNS=${GRAND_RR_BOOST_MAX_PATTERNS:-180000}
export GRAND_RR_BOOST_BATCH_SIZE=${GRAND_RR_BOOST_BATCH_SIZE:-${GRAND_BATCH_SIZE:-256}}
export GRAND_RR_BOOST_PEEL_RATIO=${GRAND_RR_BOOST_PEEL_RATIO:-${GRAND_RR_PEEL_RATIO}}
export GRAND_RR_BOOST_PEEL_MAX_BITS=${GRAND_RR_BOOST_PEEL_MAX_BITS:-${GRAND_RR_PEEL_MAX_BITS}}
export GRAND_RR_BOOST_PEEL_DENSE_MAX_VARS=${GRAND_RR_BOOST_PEEL_DENSE_MAX_VARS:-${GRAND_RR_PEEL_DENSE_MAX_VARS}}
export GRAND_RR_BOOST_PEEL_MAX_FREE_ENUM=${GRAND_RR_BOOST_PEEL_MAX_FREE_ENUM:-${GRAND_RR_PEEL_MAX_FREE_ENUM}}
export GRAND_RR_BOOST_PEEL_EXTRA_LLR_BITS=${GRAND_RR_BOOST_PEEL_EXTRA_LLR_BITS:-${GRAND_RR_PEEL_EXTRA_LLR_BITS}}
export GRAND_RR_BOOST_SNAPSHOTS=${GRAND_RR_BOOST_SNAPSHOTS:-${GRAND_RR_SNAPSHOTS}}
export GRAND_RR_BOOST_RESTART_SEED_LLR=${GRAND_RR_BOOST_RESTART_SEED_LLR:-${GRAND_RR_RESTART_SEED_LLR}}
export GRAND_RR_BOOST_RESTART_TOP_BITS=${GRAND_RR_BOOST_RESTART_TOP_BITS:-12}
export GRAND_RR_BOOST_RESTART_MAX_ORDER=${GRAND_RR_BOOST_RESTART_MAX_ORDER:-3}
export GRAND_RR_BOOST_RESTART_MAX_CANDIDATES=${GRAND_RR_BOOST_RESTART_MAX_CANDIDATES:-12}
export GRAND_RR_BOOST_RESTART_MAX_CANDIDATES_PER_SNAPSHOT=${GRAND_RR_BOOST_RESTART_MAX_CANDIDATES_PER_SNAPSHOT:-6}
export GRAND_RR_BOOST_RESTART_CANDIDATE_POOL_SIZE=${GRAND_RR_BOOST_RESTART_CANDIDATE_POOL_SIZE:-32}
export GRAND_RR_BOOST_RESTART_BIAS_ALPHA=${GRAND_RR_BOOST_RESTART_BIAS_ALPHA:-1.45}
export GRAND_RR_BOOST_RESTART_BIAS_OFFSET=${GRAND_RR_BOOST_RESTART_BIAS_OFFSET:-1.00}
export GRAND_RR_BOOST_RESTART_FORCE_ABS=${GRAND_RR_BOOST_RESTART_FORCE_ABS:-10.0}

echo "[SBATCH CONFIG] RESULTS_DIR=${RESULTS_DIR}"
echo "[SBATCH CONFIG] SNR_SWEEP=${SNR_SWEEP}"
echo "[SBATCH CONFIG] LDPC_ITERS=${LDPC_ITERS}"
echo "[SBATCH CONFIG] STAGE1_ITERS=${STAGE1_ITERS}"
echo "[SBATCH CONFIG] TARGET_FRAME_ERRORS=${TARGET_FRAME_ERRORS} MAX_FRAMES=${MAX_FRAMES}"
echo "[SBATCH CONFIG] RUN_RECEIVER2=${RUN_RECEIVER2} RUN_RECEIVER3=${RUN_RECEIVER3} RUN_RECEIVER4=${RUN_RECEIVER4}"
echo "[SBATCH CONFIG] GRAND_RR_SNAPSHOTS=${GRAND_RR_SNAPSHOTS}"
echo "[SBATCH CONFIG] GRAND_RR_RESTART_TOP_BITS=${GRAND_RR_RESTART_TOP_BITS}"
echo "[SBATCH CONFIG] GRAND_RR_RESTART_MAX_ORDER=${GRAND_RR_RESTART_MAX_ORDER}"
echo "[SBATCH CONFIG] GRAND_RR_RESTART_MAX_CANDIDATES=${GRAND_RR_RESTART_MAX_CANDIDATES}"
echo "[SBATCH CONFIG] GRAND_RR_EXTRA_LDPC_ITERS=${GRAND_RR_EXTRA_LDPC_ITERS}"

python -u HW3_PARALLEL_Narval_LDPC_GRAND_MS_PATCH.py

echo "[DONE] $(date)"
echo "[DONE] results in ${RESULTS_DIR}"
